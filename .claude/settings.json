{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/doc-context-hook.sh SessionStart",
            "statusMessage": "Loading project doc-system rules..."
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/doc-context-hook.sh PreCompact",
            "statusMessage": "Reminding to update MEMORY.md before compaction..."
          }
        ]
      }
    ]
  }
}
