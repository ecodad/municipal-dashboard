# IDE / OS
.DS_Store
Thumbs.db
.vscode/
.idea/

# Personal Claude Code overrides (project-shared config lives in
# .claude/settings.json, .claude/hooks/, and .claude/agents/, all of
# which ARE committed).
.claude/settings.local.json

# Browser/MCP debug artifacts: per-page console logs and accessibility
# snapshots that the Playwright MCP server writes during local dev.
# Useful while a session is live; never wanted in the repo.
.playwright-mcp/

# Temp / scratch
*.tmp
*.bak

# Python
__pycache__/
*.pyc
.venv/
venv/

# Scraper recon scratch (HTML dumps, test downloads, cookies)
.recon/

# Per-city scraper working dir: in-flight PDFs, parser markdown, run
# summary. Everything under agendas/{slug}/ is transient — regenerated
# on each pipeline run, then archived (committed) into {site_path}/archived/.
# The pipeline creates this directory at runtime (`mkdir -p`), so we
# don't need a tracked placeholder.
agendas/

# Local scratch / personal files kept outside the published site
maai_raw.json

# Secrets — local API keys for the Parser / Synthesizer SDK calls.
# NEVER commit a real ANTHROPIC_API_KEY. Each developer keeps their own
# copy of .env locally; only .env.example (with placeholders) is tracked.
.env
.env.local
.env.*.local
