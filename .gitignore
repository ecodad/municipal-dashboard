# IDE / OS
.DS_Store
Thumbs.db
.vscode/
.idea/

# Personal Claude Code overrides (project-shared config lives in
# .claude/settings.json and .claude/hooks/, both of which ARE committed).
.claude/settings.local.json

# Temp / scratch
*.tmp
*.bak

# Python
__pycache__/
*.pyc
.venv/
venv/

# Scraper recon scratch (HTML dumps, test downloads, cookies)
.recon/

# Per-run scraper summary; transient, regenerated each run
agendas/.last_scraper_run.json

# Secrets — local API keys for the Parser / Synthesizer SDK calls.
# NEVER commit a real ANTHROPIC_API_KEY. Each developer keeps their own
# copy of .env locally; only .env.example (with placeholders) is tracked.
.env
.env.local
.env.*.local
